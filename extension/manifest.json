{
  "manifest_version": 3,
  "name": "Alexandria AI",
  "version": "1.1",
  "description": "One-click AI video summarization inside YouTube.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Toggle Alexandria Sidebar"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "tabs", "scripting"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "http://localhost:5173/*",
    "http://localhost:8000/*"
  ]
}
