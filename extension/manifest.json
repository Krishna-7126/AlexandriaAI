{
  "manifest_version": 3,
  "name": "Alexandria AI",
  "version": "1.0",
  "description": "One-click AI video summarization for YouTube.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Summarize with Alexandria"
  },
  "permissions": ["tabs", "activeTab"],
  "host_permissions": ["*://*.youtube.com/*"]
}
