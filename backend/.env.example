# Copy this file to .env and fill in your actual values.
# DO NOT commit .env to GitHub.

# --- Required for AI summaries and Q&A ---
# Grok (x.ai) API key for Grok-powered summaries and Q&A. If using Grok, set this and ENABLE_GROK=1
XAI_API_KEY=your_xai_api_key_here
GROK_API_URL=https://api.x.ai/v1/responses

# (Legacy) Google Gemini key — not used when GROK is enabled
GOOGLE_API_KEY=your_google_api_key_here

# --- Optional: AssemblyAI for audio transcription fallback ---
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# --- Feature Flags ---
# Enable Grok AI for high-quality English summaries and Q&A (set to 1 when you have a key)
ENABLE_GROK=0
ENABLE_GEMINI=0
ENABLE_CHROMA=0
ENABLE_EMBEDDINGS=0

# Use YouTube auto-captions/yt-dlp before audio transcription
ENABLE_YOUTUBE_ASR=1

# Metadata fallback (title/description only - NOT real transcript). Keep OFF.
ENABLE_METADATA_FALLBACK=0
